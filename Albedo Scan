<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ALBEDO SCANS - Lire Manhwa, Manhua, Manga VF</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      background: #0e0e10;
      color: #e7e7e7;
      font-family: 'Segoe UI', sans-serif;
    }
    
    header {
      background: #16161a;
      padding: 0.8rem 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #252529;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    
    .logo { 
      font-size: 1.5rem; 
      font-weight: 800;
      color: #8b5cf6;
    }
    .logo span { color: #fff; }
    
    nav { display: flex; gap: 2rem; }
    nav a {
      color: #aaa;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
    }
    nav a:hover, nav a.active { color: #8b5cf6; }
    
    .search-box {
      background: #0e0e10;
      border: 1px solid #333;
      border-radius: 6px;
      padding: 0.5rem 1rem;
      color: white;
      width: 280px;
    }
    
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem 5%;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 2rem;
    }
    
    .section-header {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 1.2rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .section-header::before {
      content: '';
      width: 4px;
      height: 20px;
      background: #8b5cf6;
      border-radius: 2px;
    }
    
    .manhwa-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    
    .manhwa-item {
      background: #16161a;
      border: 1px solid #252529;
      border-radius: 8px;
      padding: 1rem;
      display: flex;
      gap: 1rem;
      transition: 0.2s;
      cursor: pointer;
    }
    
    .manhwa-item:hover {
      border-color: #8b5cf6;
      background: #1a1a20;
    }
    
    .cover {
      width: 70px;
      height: 100px;
      background: #252529;
      border-radius: 6px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }
    
    .manhwa-details { flex: 1; }
    
    .manhwa-title {
      font-weight: 700;
      font-size: 1.05rem;
      margin-bottom: 0.3rem;
    }
    
    .manhwa-meta {
      display: flex;
      gap: 1rem;
      align-items: center;
      margin-bottom: 0.6rem;
    }
    
    .rating {
      background: #8b5cf6;
      padding: 0.1rem 0.5rem;
      border-radius: 4px;
      font-size: 0.85rem;
      font-weight: bold;
    }
    
    .status {
      font-size: 0.85rem;
      color: #4ade80;
    }
    .status.completed { color: #60a5fa; }
    
    .chapter-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.9rem;
      padding: 0.3rem 0;
      color: #aaa;
    }
    
    .chapter-row:hover { color: #8b5cf6; }
    
    .new-tag {
      background: #ef4444;
      color: white;
      font-size: 0.7rem;
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
      margin-left: 0.5rem;
    }
    
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    
    .sidebar-box {
      background: #16161a;
      border: 1px solid #252529;
      border-radius: 8px;
      padding: 1.2rem;
    }
    
    .popular-item {
      display: flex;
      gap: 0.8rem;
      margin-bottom: 1rem;
      cursor: pointer;
    }
    
    .popular-rank {
      font-size: 1.5rem;
      font-weight: 800;
      color: #333;
      width: 25px;
    }
    
    .popular-item:nth-child(1) .popular-rank { color: #fbbf24; }
    .popular-item:nth-child(2) .popular-rank { color: #94a3b8; }
    .popular-item:nth-child(3) .popular-rank { color: #f97316; }
    
    .popular-cover {
      width: 45px;
      height: 60px;
      background: #252529;
      border-radius: 4px;
      flex-shrink: 0;
    }
    
    .popular-info h4 {
      font-size: 0.9rem;
      margin-bottom: 0.2rem;
    }
    
    .popular-genre {
      font-size: 0.75rem;
      color: #666;
    }
    
    footer {
      background: #16161a;
      text-align: center;
      padding: 2rem;
      margin-top: 3rem;
      border-top: 1px solid #252529;
      color: #666;
      font-size: 0.9rem;
    }
    
    @media (max-width: 1024px) {
      .container { grid-template-columns: 1fr; }
      .sidebar { order: -1; }
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">ALBEDO<span>SCANS</span></div>
    <nav>
      <a href="#" class="active">Accueil</a>
      <a href="#">Manga List</a>
      <a href="#">Genres</a>
      <a href="#">Discord</a>
    </nav>
    <input type="text" class="search-box" placeholder="Rechercher...">
  </header>

  <main class="container">
    <div class="main-content">
      <h2 class="section-header">Latest Releases</h2>
      <div class="manhwa-list">
        
        <div class="manhwa-item">
          <div class="cover">👑</div>
          <div class="manhwa-details">
            <div class="manhwa-title">Le Roi Démon est de Retour</div>
            <div class="manhwa-meta">
              <span class="rating">9.8</span>
              <span class="status">En cours</span>
            </div>
            <div class="chapter-row">
              <span>Chapitre 78</span>
              <span>Il y a 2h <span class="new-tag">NEW</span></span>
            </div>
            <div class="chapter-row">
              <span>Chapitre 77</span>
              <span>Hier</span>
            </div>
            <div class="chapter-row">
              <span>Chapitre 76</span>
              <span>Il y a 3 jours</span>
            </div>
          </div>
        </div>

        <div class="manhwa-item">
          <div class="cover">⚔️</div>
          <div class="manhwa-details">
            <div class="manhwa-title">Solo Leveling: Ragnarok</div>
            <div class="manhwa-meta">
              <span class="rating">9.5</span>
              <span class="status">En cours</span>
            </div>
            <div class="chapter-row">
              <span>Chapitre 12</span>
              <span>Il y a 5h <span class="new-tag">NEW</span></span>
            </div>
            <div class="chapter-row">
              <span>Chapitre 11</span>
              <span>Il y a 2 jours</span>
            </div>
          </div>
        </div>

        <div class="manhwa-item">
          <div class="cover">🌸</div>
          <div class="manhwa-details">
            <div class="manhwa-title">La Fée Empoisonneuse</div>
            <div class="manhwa-meta">
              <span class="rating">8.7</span>
              <span class="status">En cours</span>
            </div>
            <div class="chapter-row">
              <span>Chapitre 45</span>
              <span>Il y a 1 jour</span>
            </div>
            <div class="chapter-row">
              <span>Chapitre 44</span>
              <span>Il y a 4 jours</span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <aside class="sidebar">
      <div class="sidebar-box">
        <h2 class="section-header">Popular</h2>
        
        <div class="popular-item">
          <div class="popular-rank">1</div>
          <div class="popular-cover"></div>
          <div class="popular-info">
            <h4>Return of Mount Hua</h4>
            <div class="popular-genre">Action, Aventure</div>
            <div class="rating" style="display:inline-block; margin-top:0.2rem;">9.8</div>
          </div>
        </div>

        <div class="popular-item">
          <div class="popular-rank">2</div>
          <div class="popular-cover"></div>
          <div class="popular-info">
            <h4>Nano Machine</h4>
            <div class="popular-genre">Action, Fantasy</div>
            <div class="rating" style="display:inline-block; margin-top:0.2rem;">9.3</div>
          </div>
        </div>

        <div class="popular-item">
          <div class="popular-rank">3</div>
          <div class="popular-cover"></div>
          <div class="popular-info">
            <h4>Regressed Mercenary</h4>
            <div class="popular-genre">Action, Murim</div>
            <div class="rating" style="display:inline-block; margin-top:0.2rem;">9.7</div>
          </div>
        </div>

      </div>
    </aside>
  </main>

  <footer>
    <p>© 2026 ALBEDO SCANS. Tous droits réservés.</p>
    <p>Rejoins le Discord pour les sorties en avance.</p>
  </footer>

  <script>
    // Recherche
    document.querySelector('.search-box').oninput = (e) => {
      const search = e.target.value.toLowerCase();
      document.querySelectorAll('.manhwa-item').forEach(item => {
        const title = item.querySelector('.manhwa-title').textContent.toLowerCase();
        item.style.display = title.includes(search) ? 'flex' : 'none';
      });
    };

    // Clic sur un manhwa
    document.querySelectorAll('.manhwa-item, .popular-item').forEach(item => {
      item.onclick = () => alert('Ouvre la page du manhwa');
    });
  </script>
</body>
</html>
