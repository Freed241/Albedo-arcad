<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ALBEDO Arcade - Jeux Gratuits</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      background: #0a0a0f;
      color: #fff;
      font-family: 'Segoe UI', sans-serif;
    }
    
    header {
      background: #15151f;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 2px solid #8b5cf6;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    
    .logo { 
      font-size: 1.8rem; 
      font-weight: bold;
      color: #8b5cf6;
      text-shadow: 0 0 10px #8b5cf6;
    }
    
    .search {
      padding: 0.6rem 1.2rem;
      background: #0a0a0f;
      border: 1px solid #8b5cf6;
      color: white;
      border-radius: 20px;
      width: 350px;
    }
    
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
    }
    
    .game-player {
      width: 100%;
      aspect-ratio: 16/9;
      background: #000;
      border: 2px solid #8b5cf6;
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 1.5rem;
      box-shadow: 0 0 30px rgba(139, 92, 246, 0.3);
    }
    
    .game-player iframe {
      width: 100%;
      height: 100%;
      border: none;
    }
    
    .game-details {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 2rem;
      margin-bottom: 3rem;
    }
    
    .game-info h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }
    
    .tags {
      display: flex;
      gap: 0.5rem;
      margin: 1rem 0;
    }
    
    .tag {
      padding: 0.3rem 0.8rem;
      background: #8b5cf6;
      border-radius: 6px;
      font-size: 0.9rem;
    }
    
    .btn-play {
      padding: 1rem 2rem;
      background: #8b5cf6;
      border: none;
      color: white;
      font-size: 1.1rem;
      border-radius: 8px;
      cursor: pointer;
      transition: 0.3s;
    }
    
    .btn-play:hover {
      box-shadow: 0 0 25px #8b5cf6;
      transform: scale(1.05);
    }
    
    h2 {
      margin: 2rem 0 1rem 0;
      font-size: 1.8rem;
    }
    
    .games-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.5rem;
    }
    
    .game-card {
      background: #15151f;
      border-radius: 12px;
      overflow: hidden;
      transition: 0.3s;
      cursor: pointer;
      border: 1px solid transparent;
    }
    
    .game-card:hover {
      transform: translateY(-5px);
      border-color: #8b5cf6;
      box-shadow: 0 5px 20px rgba(139, 92, 246, 0.4);
    }
    
    .game-thumb {
      width: 100%;
      height: 140px;
      background: linear-gradient(135deg, #1a0a2e, #0a0a0f);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
    }
    
    .game-card-info {
      padding: 1rem;
    }
    
    .game-card-title {
      font-weight: bold;
      margin-bottom: 0.3rem;
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">ALBEDO <span style="color:#fff">ARCADE</span></div>
    <input type="text" class="search" placeholder="Rechercher un jeu...">
  </header>

  <div class="container">
    <div class="game-player">
      <iframe src="https://html5.gamedistribution.com/rvvASMiM/?gd_sdk_referrer_url=https://example.com" allowfullscreen></iframe>
    </div>
    
    <div class="game-details">
      <div class="game-info">
        <h1>2048 Classic</h1>
        <div class="tags">
          <span class="tag">Puzzle</span>
          <span class="tag">Logique</span>
          <span class="tag">Solo</span>
        </div>
        <p>Fusionne les tuiles pour atteindre 2048. Simple à comprendre, dur à maîtriser.</p>
      </div>
      <button class="btn-play">▶ Plein écran</button>
    </div>

    <h2>Plus de jeux</h2>
    <div class="games-grid">
      <div class="game-card">
        <div class="game-thumb">🏃</div>
        <div class="game-card-info">
          <div class="game-card-title">Temple Runner</div>
          <span class="tag">Action</span>
        </div>
      </div>
      
      <div class="game-card">
        <div class="game-thumb">🚀</div>
        <div class="game-card-info">
          <div class="game-card-title">Space Blaster</div>
          <span class="tag">Arcade</span>
        </div>
      </div>
      
      <div class="game-card">
        <div class="game-thumb">⚽</div>
        <div class="game-card-info">
          <div class="game-card-title">Penalty King</div>
          <span class="tag">Sport</span>
        </div>
      </div>
      
      <div class="game-card">
        <div class="game-thumb">🧠</div>
        <div class="game-card-info">
          <div class="game-card-title">Brain Teaser</div>
          <span class="tag">Puzzle</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Plein écran pour le jeu
    document.querySelector('.btn-play').onclick = () => {
      const iframe = document.querySelector('.game-player iframe');
      if (iframe.requestFullscreen) {
        iframe.requestFullscreen();
      }
    };

    // Recherche basique
    document.querySelector('.search').oninput = (e) => {
      const search = e.target.value.toLowerCase();
      document.querySelectorAll('.game-card').forEach(card => {
        const title = card.querySelector('.game-card-title').textContent.toLowerCase();
        card.style.display = title.includes(search) ? 'block' : 'none';
      });
    };

    // Clic sur une carte de jeu
    document.querySelectorAll('.game-card').forEach(card => {
      card.onclick = () => {
        alert('Ici tu charges le nouveau jeu dans l\'iframe du dessus');
      }
    });
  </script>
</body>
</html>
